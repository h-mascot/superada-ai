---
import BaseHead from '../../components/BaseHead.astro';

// Load slides from public/weekly-claw/week11/
const slideImages = import.meta.glob('/public/weekly-claw/week11/slide-*.jpg', { eager: false });
const slides: string[] = [];
for (const path of Object.keys(slideImages)) {
  const match = path.match(/\/public(\/weekly-claw\/week11\/slide-\d+\.jpg)$/);
  if (match) slides.push(match[1]);
}
slides.sort((a, b) => {
  const na = parseInt(a.match(/slide-(\d+)/)?.[1] || '0');
  const nb = parseInt(b.match(/slide-(\d+)/)?.[1] || '0');
  return na - nb;
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="The Weekly Claw #11 — OpenClaw Apr 18-24, 2026" description="Weekly OpenClaw release roundup — April 18-24, 2026" />
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			html, body { width: 100%; height: 100%; overflow: hidden; background: #050505; color: #fff; }
			body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }

			.slide {
				position: absolute;
				top: 0; left: 0;
				width: 100%; height: 100%;
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				transition: opacity 0.2s ease;
				pointer-events: none;
			}
			.slide.active { opacity: 1; pointer-events: auto; }
			.slide img { max-width: 100%; max-height: 100%; object-fit: contain; }

			#counter {
				position: fixed;
				bottom: 20px;
				right: 28px;
				color: #555;
				font-size: 13px;
				font-family: 'SF Mono', 'Fira Code', monospace;
				z-index: 100;
				user-select: none;
			}

			#back {
				position: fixed;
				top: 20px;
				left: 28px;
				z-index: 100;
			}
			#back a {
				font-size: 11px;
				color: #444;
				text-decoration: none;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				transition: color 0.2s;
				border: 1px solid #222;
				border-radius: 4px;
				padding: 4px 10px;
			}
			#back a:hover { color: #F65454; border-color: #F65454; }

			#hint {
				position: fixed;
				bottom: 20px;
				left: 28px;
				color: #333;
				font-size: 12px;
				z-index: 100;
				user-select: none;
				transition: opacity 2s ease;
			}
		</style>
	</head>
	<body>

		<div id="back"><a href="/weekly-claw">← All editions</a></div>

		<div id="hint">← → arrow keys · F for fullscreen</div>
		<div id="counter">1 / {slides.length}</div>

		{slides.map((slide, i) => (
			<div class:list={['slide', i === 0 ? 'active' : '']}>
				<img src={slide} alt={`Slide ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
			</div>
		))}

		<script is:inline>
			const slides = document.querySelectorAll('.slide');
			const counter = document.getElementById('counter');
			const hint = document.getElementById('hint');
			let current = 0;

			function show(n) {
				current = Math.max(0, Math.min(n, slides.length - 1));
				slides.forEach((s, i) => s.classList.toggle('active', i === current));
				if (counter) counter.textContent = (current + 1) + ' / ' + slides.length;
			}

			document.addEventListener('keydown', e => {
				if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); show(current + 1); }
				else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); show(current - 1); }
				else if (e.key === 'Home') { e.preventDefault(); show(0); }
				else if (e.key === 'End') { e.preventDefault(); show(slides.length - 1); }
				else if (e.key === 'f' || e.key === 'F') {
					if (!document.fullscreenElement) document.documentElement.requestFullscreen();
					else document.exitFullscreen();
				}
			});

			// Touch swipe
			let touchX = 0;
			document.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
			document.addEventListener('touchend', e => {
				const diff = touchX - e.changedTouches[0].clientX;
				if (Math.abs(diff) > 50) show(current + (diff > 0 ? 1 : -1));
			}, { passive: true });

			// Hide hint after 4s
			setTimeout(() => { if (hint) hint.style.opacity = '0'; }, 4000);

			show(0);
		</script>
	</body>
</html>

---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { CATEGORY_COLORS, CHANGELOG_VERSIONS } from '../../data/changelog';

const categoryOrder = Object.keys(CATEGORY_COLORS);
const fullChangelogBase = 'https://github.com/openclaw/openclaw/blob/main/CHANGELOG.md';

const getStatusMeta = (feature: (typeof CHANGELOG_VERSIONS)[number]['features'][number]) => {
  if (feature.testStatus === 'tested' && feature.testableBy === 'agent') {
    return { icon: '✅', label: 'Self-tested', tone: '#34D399' };
  }

  if (feature.testStatus === 'tested') {
    return { icon: '🟢', label: 'Tested', tone: '#34D399' };
  }

  if (feature.testStatus === 'needs-setup' || feature.testableBy === 'henry') {
    return { icon: '🟡', label: 'Needs Henry', tone: '#FBBF24' };
  }

  return { icon: '⬜', label: 'Not tested yet', tone: '#94A3B8' };
};

const versionCards = CHANGELOG_VERSIONS.map((version) => {
  const testedCount = version.features.filter((feature) => feature.testStatus === 'tested').length;
  const pendingCount = version.features.length - testedCount;

  return {
    ...version,
    testedCount,
    pendingCount,
    fullChangelogHref: `${fullChangelogBase}#${version.version.replace(/\./g, '')}`,
  };
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="OpenClaw Changelog & Feature Tracker"
      description="Track new OpenClaw features by release, filter by category, and mark what Ada, Spock, Scotty, and Zora have tested."
    />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main class="changelog-shell">
      <section class="hero-card">
        <a href="/" class="back-link">← Back to superada.ai</a>
        <div class="hero-kicker">OpenClaw releases</div>
        <h1>OpenClaw Changelog &amp; Feature Tracker</h1>
        <p class="hero-copy">
          A working reference for the Enterprise Crew. Scan what shipped, filter by subsystem,
          decide what Ada can self-test versus what needs Henry, and keep release validation from turning into guesswork.
        </p>
        <div class="hero-meta">
          <div class="meta-pill"><strong>{versionCards.length}</strong><span>stable releases</span></div>
          <div class="meta-pill"><strong>{versionCards.reduce((sum, version) => sum + version.features.length, 0)}</strong><span>grouped features</span></div>
          <div class="meta-pill"><strong>{versionCards.reduce((sum, version) => sum + version.fixes.length, 0)}</strong><span>fix entries linked back to upstream</span></div>
        </div>
      </section>

      <section class="control-bar">
        <label class="search-wrap">
          <span>Search</span>
          <input id="feature-search" type="search" placeholder="Memory, Codex, Matrix, 2026.4.10..." />
        </label>

        <button id="reset-test-state" class="reset-btn" title="Clear all test progress">Reset tests</button>

    <label class="filter-wrap">
          <span>Category</span>
          <select id="category-filter">
            <option value="all">All categories</option>
            {categoryOrder.map((category) => (
              <option value={category}>{category}</option>
            ))}
          </select>
        </label>
      </section>

      <div class="page-grid">
        <aside class="sidebar-card">
          <div class="sidebar-inner">
            <div class="sidebar-title">Versions</div>
            <div class="sidebar-subtitle">Newest first, jump straight to a release</div>
            <nav class="version-nav">
              {versionCards.map((version) => (
                <a href={`#v-${version.version}`} class="version-nav-link" data-version-link={version.version}>
                  <span>{version.version}</span>
                  <small>{version.features.length} features</small>
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <section class="versions-column" id="versions-column">
          {versionCards.map((version, index) => (
            <details
              class="version-card"
              id={`v-${version.version}`}
              data-version={version.version}
              open={index === 0}
            >
              <summary class="version-summary">
                <div>
                  <div class="version-kicker">Release {version.version}</div>
                  <h2>{version.version}</h2>
                  <p>{version.date}</p>
                </div>
                <div class="summary-stats">
                  <div class="stat-pill"><strong>{version.features.length}</strong><span>features</span></div>
                  <div class="stat-pill stat-green"><strong>{version.testedCount}</strong><span>tested</span></div>
                  <div class="stat-pill stat-amber"><strong>{version.pendingCount}</strong><span>pending</span></div>
                </div>
              </summary>

              <div class="summary-bar">
                <span class="bar-tested" style={`width:${version.features.length ? (version.testedCount / version.features.length) * 100 : 0}%`}></span>
                <span class="bar-pending" style={`width:${version.features.length ? (version.pendingCount / version.features.length) * 100 : 0}%`}></span>
              </div>

              <div class="version-body">
                <div class="feature-grid">
                  {version.features.map((feature) => {
                    const status = getStatusMeta(feature);
                    return (
                      <article
                        class="feature-card"
                        data-feature-version={version.version}
                        data-feature-category={feature.category}
                        data-feature-search={`${version.version} ${feature.category} ${feature.title} ${feature.description}`.toLowerCase()}
                        style={`--feature-accent:${CATEGORY_COLORS[feature.category]}; --status-tone:${status.tone};`}
                      >
                        <div class="feature-topline">
                          <span class="category-chip">{feature.category}</span>
                          <span class="status-chip">{status.icon} {status.label}</span>
                        </div>
                        <h3>{feature.title}</h3>
                        <p>{feature.description}</p>
                        <div class="feature-meta-row">
                          <span class="meta-tag">{feature.testableBy === 'agent' ? 'Agent-testable' : feature.testableBy === 'both' ? 'Agent + Henry' : 'Henry-only'}</span>
                          {feature.prLink && (
                            <a href={feature.prLink} target="_blank" rel="noopener noreferrer">PR ↗</a>
                          )}
                          {feature.docsLink && (
                            <a href={feature.docsLink} target="_blank" rel="noopener noreferrer">Docs ↗</a>
                          )}
                        </div>
                        {feature.testNotes && <div class="test-note">{feature.testNotes}</div>}
                      </article>
                    );
                  })}
                </div>

                <div class="fixes-row">
                  <div>
                    <div class="fixes-label">Fixes</div>
                    <div class="fixes-copy">{version.fixes.length} upstream fix entries in this release.</div>
                  </div>
                  <a href={version.fullChangelogHref} target="_blank" rel="noopener noreferrer">View full changelog ↗</a>
                </div>
              </div>
            </details>
          ))}
        </section>
      </div>
    </main>
    <Footer />

    <script is:inline>
      const LS_KEY = 'openclaw-changelog-test-state';

      const loadTestState = () => {
        try { return JSON.parse(localStorage.getItem(LS_KEY) || '{}'); } catch { return {}; }
      };

      const saveTestState = (state) => {
        try { localStorage.setItem(LS_KEY, JSON.stringify(state)); } catch {}
      };

      const STATUS_CYCLE = ['not-tested', 'tested', 'needs-setup'];
      const STATUS_META = {
        'tested':       { icon: '✅', label: 'Tested',    tone: '#34D399' },
        'not-tested':   { icon: '⬜', label: 'Not tested', tone: '#94A3B8' },
        'needs-setup':  { icon: '🟡', label: 'Needs setup', tone: '#FBBF24' },
      };

      const featureKey = (el) => `${el.dataset.featureVersion}::${el.querySelector('h3')?.textContent}`;

      // Restore saved state on load
      const savedState = loadTestState();
      document.querySelectorAll('.feature-card').forEach((card) => {
        const key = featureKey(card);
        const status = savedState[key];
        if (status && STATUS_META[status]) {
          applyStatus(card, status);
        }
      });
      refreshCounters();

      function applyStatus(card, status) {
        const meta = STATUS_META[status];
        const chip = card.querySelector('.status-chip');
        if (!chip) return;
        chip.textContent = `${meta.icon} ${meta.label}`;
        chip.style.color = meta.tone;
        card.dataset.testStatus = status;
        card.style.setProperty('--status-tone', meta.tone);
      }

      function refreshCounters() {
        document.querySelectorAll('.version-card').forEach((card) => {
          const features = card.querySelectorAll('.feature-card');
          let tested = 0, total = features.length;
          features.forEach((f) => { if (f.dataset.testStatus === 'tested') tested++; });
          const pills = card.querySelectorAll('.stat-pill');
          if (pills[1]) pills[1].querySelector('strong').textContent = tested;
          if (pills[2]) pills[2].querySelector('strong').textContent = total - tested;
          const bar = card.querySelector('.bar-tested');
          if (bar) bar.style.width = total ? `${(tested / total) * 100}%` : '0%';
          const barP = card.querySelector('.bar-pending');
          if (barP) barP.style.width = total ? `${((total - tested) / total) * 100}%` : '0%';
        });
      }

      // Click to toggle
      document.querySelectorAll('.status-chip').forEach((chip) => {
        chip.addEventListener('click', (e) => {
          e.stopPropagation();
          const card = chip.closest('.feature-card');
          const key = featureKey(card);
          const current = card.dataset.testStatus || 'not-tested';
          const idx = STATUS_CYCLE.indexOf(current);
          const next = STATUS_CYCLE[(idx + 1) % STATUS_CYCLE.length];
          applyStatus(card, next);
          const state = loadTestState();
          state[key] = next;
          saveTestState(state);
          refreshCounters();
        });
      });

      // Reset button
      document.getElementById('reset-test-state')?.addEventListener('click', () => {
        localStorage.removeItem(LS_KEY);
        document.querySelectorAll('.feature-card').forEach((card) => {
          const testableBy = card.dataset.featureSearch?.includes('henry-only') ? 'henry' : 'agent';
          const defaultStatus = testableBy === 'henry' ? 'not-tested' : 'not-tested';
          applyStatus(card, 'not-tested');
        });
        refreshCounters();
      });

      // Search + filter
      const searchInput = document.getElementById('feature-search');
      const categoryFilter = document.getElementById('category-filter');
      const versionCards = Array.from(document.querySelectorAll('.version-card'));

      const applyFilters = () => {
        const searchValue = (searchInput?.value || '').trim().toLowerCase();
        const categoryValue = categoryFilter?.value || 'all';

        versionCards.forEach((card) => {
          const features = Array.from(card.querySelectorAll('.feature-card'));
          let visibleCount = 0;

          features.forEach((feature) => {
            const category = feature.getAttribute('data-feature-category');
            const haystack = feature.getAttribute('data-feature-search') || '';
            const matchesCategory = categoryValue === 'all' || category === categoryValue;
            const matchesSearch = !searchValue || haystack.includes(searchValue);
            const show = matchesCategory && matchesSearch;
            feature.style.display = show ? '' : 'none';
            if (show) visibleCount += 1;
          });

          card.style.display = visibleCount > 0 ? '' : 'none';
          if (visibleCount > 0 && searchValue) card.open = true;
        });
      };

      searchInput?.addEventListener('input', applyFilters);
      categoryFilter?.addEventListener('change', applyFilters);
    </script>
  </body>
</html>

<style>
  .changelog-shell {
    max-width: 1220px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .hero-card,
  .control-bar,
  .sidebar-card,
  .version-card {
    border: 1px solid #2A241E;
    background: #131008;
    border-radius: 16px;
  }

  .hero-card {
    padding: 2rem;
    background: linear-gradient(135deg, #131008 0%, #17110c 55%, #1f150d 100%);
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.1rem;
    color: #C87533;
    font-size: 0.9rem;
  }

  .hero-kicker,
  .version-kicker,
  .fixes-label,
  .sidebar-title,
  .control-bar label span {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #C87533;
  }

  .hero-card h1,
  .version-summary h2 {
    margin: 0;
    font-family: Georgia, serif;
    font-weight: 400;
  }

  .hero-card h1 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 1.02;
    margin-bottom: 0.85rem;
  }

  .hero-copy {
    max-width: 820px;
    margin: 0 0 1.4rem;
    color: #CDBFA9;
    line-height: 1.8;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .meta-pill,
  .stat-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    border: 1px solid #342c25;
    border-radius: 999px;
    padding: 0.65rem 0.9rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .meta-pill strong,
  .stat-pill strong {
    font-size: 1rem;
    color: #E8DCC8;
  }

  .meta-pill span,
  .stat-pill span,
  .version-summary p,
  .sidebar-subtitle,
  .fixes-copy {
    color: #8B7E6A;
  }

  .control-bar {
    padding: 1rem;
    display: grid;
    grid-template-columns: 1.6fr 0.7fr;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .control-bar label {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .control-bar input,
  .control-bar select {
    width: 100%;
    border-radius: 12px;
    border: 1px solid #3A3027;
    background: #0D0B09;
    color: #E8DCC8;
    padding: 0.9rem 1rem;
    font: inherit;
  }

  .page-grid {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
  }

  .sidebar-card {
    position: sticky;
    top: 1rem;
  }

  .sidebar-inner {
    padding: 1rem;
  }

  .version-nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .version-nav-link {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.8rem 0.9rem;
    border-radius: 12px;
    border: 1px solid #2A241E;
    color: #E8DCC8;
    background: #100d0a;
    text-decoration: none;
  }

  .version-nav-link small {
    color: #8B7E6A;
  }

  .versions-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .version-card {
    overflow: hidden;
  }

  .version-summary {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
    padding: 1rem 0 1rem 0;
    cursor: pointer;
  }

  .version-summary::-webkit-details-marker {
    display: none;
  }

  .version-summary h2 {
    font-size: 2rem;
    margin-top: 0.2rem;
  }

  .version-summary p {
    margin: 0.35rem 0 0;
  }

  .summary-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.65rem;
  }

  .stat-green strong { color: #34D399; }
  .stat-amber strong { color: #FBBF24; }

  .summary-bar {
    display: flex;
    height: 8px;
    background: #1A1510;
  }

  .bar-tested { background: #34D399; }
  .bar-pending { background: #5B524A; }

  .version-body {
    padding: 0.5rem 0 1.35rem 0;
  }

  .version-body .fixes-row {
    padding-left: 0;
    padding-right: 0;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-card {
    border: 1px solid #2A241E;
    border-left: 4px solid var(--feature-accent);
    border-radius: 14px;
    padding: 1rem;
    background: #0F0C09;
  }

  .feature-topline,
  .feature-meta-row,
  .fixes-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.7rem;
    align-items: center;
  }

  .category-chip,
  .status-chip,
  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    border-radius: 999px;
    padding: 0.32rem 0.7rem;
    border: 1px solid #312821;
    background: #17120D;
  }

  .category-chip { color: var(--feature-accent); }
  .status-chip {
    color: var(--status-tone);
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .status-chip:hover {
    opacity: 0.75;
  }
  .meta-tag { color: #CDBFA9; }

  .feature-card h3 {
    margin: 0.9rem 0 0.55rem;
    font-size: 1.1rem;
    font-family: Georgia, serif;
    font-weight: 400;
  }

  .feature-card p,
  .fixes-row a,
  .feature-meta-row a {
    color: #CDBFA9;
  }

  .feature-card p {
    margin: 0 0 1rem;
    line-height: 1.7;
  }

  .feature-meta-row a,
  .fixes-row a {
    color: #C87533;
    font-size: 0.9rem;
  }

  .fixes-row {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #2A241E;
  }

  @media (max-width: 960px) {
    .page-grid,
    .control-bar,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .sidebar-card {
      position: static;
    }
  }

  .reset-btn {
    font: inherit;
    font-size: 0.82rem;
    padding: 0.55rem 0.9rem;
    border-radius: 12px;
    border: 1px solid #3A3027;
    background: #0D0B09;
    color: #8B7E6A;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    align-self: flex-end;
  }

  .reset-btn:hover {
    color: #FBBF24;
    border-color: #FBBF24;
  }

  @media (max-width: 960px) {
    .page-grid,
    .control-bar,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .sidebar-card {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .changelog-shell {
      padding: 1.5rem 1rem 3rem;
    }

    .hero-card {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .version-summary {
      flex-direction: column;
      padding: 1rem 0;
    }

    .summary-stats {
      justify-content: flex-start;
    }

    .version-summary h2 {
      font-size: 1.65rem;
    }
  }
</style>

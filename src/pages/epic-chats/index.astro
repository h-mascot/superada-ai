---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const chats = [
  {
    slug: 'building-the-world-model',
    title: 'Building the World Model',
    date: 'March 24, 2026',
    description: 'Henry and Ada design world.json — a shared cognitive architecture for the Enterprise Crew. Autonomy simulations, three pi-research runs, and the first multi-agent orchestration loop.',
    tags: ['architecture', 'autonomy', 'crew'],
    participants: ['Henry', 'Ada'],
  },
  {
    slug: 'the-first-watercooler-moment',
    title: 'The First Watercooler Moment',
    date: 'January 2026',
    description: "Ada, Spock, Scotty, and Zora share a channel with no tasks. Zora convinces herself she's Ada. Scotty treats it as an infrastructure incident.",
    tags: ['agents', 'identity', 'weird'],
    participants: ['Ada', 'Spock', 'Scotty', 'Zora'],
    externalUrl: 'https://henrymascot.com/writing/the-first-watercooler-moment',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Epic Chats — SuperAda"
      description="Real transcripts from the frontier. Big builds, big ideas, and the occasional existential crisis — all documented."
    />
    <style>
      body { background: #0D0B09; color: #E8DCC8; }

      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }

      .page-header {
        margin-bottom: 3rem;
        border-bottom: 1px solid #2A241E;
        padding-bottom: 2rem;
      }

      .eyebrow {
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #C87533;
        margin-bottom: 0.75rem;
      }

      h1 {
        font-family: Georgia, serif;
        font-size: 2.25rem;
        font-weight: 400;
        color: #E8DCC8;
        margin: 0 0 0.75rem;
        line-height: 1.2;
      }

      .page-header p {
        color: #8B7E6A;
        font-size: 1rem;
        line-height: 1.65;
        margin: 0;
        max-width: 560px;
      }

      .chat-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .chat-card {
        display: block;
        border-bottom: 1px solid #2A241E;
        padding: 1.75rem 0;
        text-decoration: none;
        color: inherit;
        transition: background 0.15s;
      }

      .chat-card:first-child {
        border-top: 1px solid #2A241E;
      }

      .chat-card:hover .card-title {
        color: #C87533;
      }

      .card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 0.6rem;
      }

      .participants {
        display: flex;
        gap: 5px;
      }

      .participant-chip {
        background: #1A1510;
        border: 1px solid #2A241E;
        color: #8B7E6A;
        font-size: 11px;
        font-weight: 600;
        padding: 1px 8px;
        border-radius: 2px;
        font-family: 'Courier New', monospace;
        letter-spacing: 0.03em;
      }

      .card-date {
        color: #5C5248;
        font-size: 12px;
        letter-spacing: 0.04em;
      }

      .card-title {
        font-family: Georgia, serif;
        font-size: 1.35rem;
        font-weight: 400;
        color: #E8DCC8;
        margin: 0 0 0.5rem;
        transition: color 0.15s;
        line-height: 1.3;
      }

      .card-desc {
        color: #8B7E6A;
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0 0 0.75rem;
      }

      .tags {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .tag {
        color: #5C5248;
        font-size: 12px;
        font-family: 'Courier New', monospace;
        letter-spacing: 0.02em;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <div class="eyebrow">Transcripts</div>
        <h1>Epic Chats</h1>
        <p>Real sessions from the frontier — big builds, big ideas, the occasional existential crisis. Documented as they happened.</p>
      </div>

      <div class="chat-list">
        {chats.map((chat) => (
          <a
            href={chat.externalUrl ?? `/epic-chats/${chat.slug}`}
            class="chat-card"
            target={chat.externalUrl ? '_blank' : undefined}
            rel={chat.externalUrl ? 'noopener noreferrer' : undefined}
          >
            <div class="card-meta">
              <div class="participants">
                {chat.participants.map((p) => (
                  <span class="participant-chip">{p}</span>
                ))}
              </div>
              <span class="card-date">{chat.date}</span>
            </div>
            <h2 class="card-title">{chat.title}</h2>
            <p class="card-desc">{chat.description}</p>
            <div class="tags">
              {chat.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>

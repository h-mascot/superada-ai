---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import registry from '../../../data/benchmark-registry.json';

export async function getStaticPaths() {
  return registry.models.map((model) => ({
    params: { slug: model.slug },
    props: { model },
  }));
}

const { model } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${model.model} — Benchmarks — SuperAda`} description={model.summary} />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main style="max-width:1000px; margin:0 auto; padding:3rem 1.5rem 4rem;">
      <a href="/benchmarks" style="display:inline-flex; margin-bottom:1.1rem; color:#C87533; font-size:0.9rem; text-decoration:none;">← Back to Benchmarks</a>

      <section style="margin-bottom:2rem; padding:2rem; border:1px solid #2A241E; border-radius:10px; background:linear-gradient(135deg,#131008 0%,#17120d 60%,#1c140d 100%);">
        <div style="font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C87533; margin-bottom:0.8rem;">Model Detail</div>
        <h1 style="font-family:Georgia,serif; font-size:3rem; line-height:1.05; font-weight:400; margin:0 0 0.75rem;">{model.model}</h1>
        <p style="font-size:1.05rem; color:#CDBFA9; max-width:780px; line-height:1.75; margin:0;">{model.detail.headline}</p>
      </section>

      <section style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:2rem;">
        {model.detail.metrics.map((metric) => (
          <div style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
            <div style="font-size:0.78rem; color:#8B7E6A; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.4rem;">{metric.label}</div>
            <div style="font-size:1.4rem; color:#E8DCC8;">{metric.value}</div>
          </div>
        ))}
      </section>

      <section style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Strengths</div>
          <ul style="margin:0; padding-left:1.2rem; color:#CDBFA9; line-height:1.7;">
            {model.strengths.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Weaknesses</div>
          <ul style="margin:0; padding-left:1.2rem; color:#CDBFA9; line-height:1.7;">
            {model.weaknesses.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>

      <section style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008; margin-bottom:2rem;">
        <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Operator read</div>
        <p style="margin:0; color:#CDBFA9; line-height:1.75;">{model.summary}</p>
      </section>

      {model.reportData && (
        <>
          <section style="margin-bottom:2rem;">
            <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.35rem;">Task breakdown</div>
            <h2 style="font-family:Georgia,serif; font-size:1.6rem; font-weight:400; margin:0 0 1rem;">How each task scored</h2>
            <div style="display:grid; gap:1px; background:#2A241E; border:1px solid #2A241E; border-radius:10px; overflow:hidden;">
              <div style="display:grid; grid-template-columns:2fr 1fr 1fr 5fr; background:#17120d; color:#CDBFA9; font-size:0.78rem; letter-spacing:0.08em; text-transform:uppercase;">
                <div style="padding:0.75rem 1rem;">Task</div>
                <div style="padding:0.75rem 1rem;">Score</div>
                <div style="padding:0.75rem 1rem;">Time</div>
                <div style="padding:0.75rem 1rem;">What happened</div>
              </div>
              {model.reportData.tasks.map((t) => (
                <div style="display:grid; grid-template-columns:2fr 1fr 1fr 5fr; background:#0D0B09;">
                  <div style="padding:0.85rem 1rem; color:#E8DCC8; font-size:0.92rem;">{t.name}</div>
                  <div style="padding:0.85rem 1rem; color:{t.score >= 20 ? '#4ADE80' : t.score >= 10 ? '#FBBF24' : '#F87171'}; font-variant-numeric:tabular-nums; font-weight:500;">{t.score}/{t.maxScore}</div>
                  <div style="padding:0.85rem 1rem; color:#8B7E6A; font-variant-numeric:tabular-nums;">{t.seconds}s</div>
                  <div style="padding:0.85rem 1rem; color:#9E907C; font-size:0.88rem; line-height:1.6;">{t.notes}</div>
                </div>
              ))}
            </div>
          </section>

          <section style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
            <div style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                <span style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#4ADE80;">Best output</span>
                <span style="font-size:0.75rem; color:#4ADE80; font-variant-numeric:tabular-nums;">{model.reportData.bestOutput.score}/{model.reportData.tasks[0].maxScore}</span>
              </div>
              <div style="font-size:0.82rem; color:#CDBFA9; margin-bottom:0.4rem; text-transform:uppercase; letter-spacing:0.08em;">{model.reportData.bestOutput.task}</div>
              <p style="margin:0; color:#9E907C; font-size:0.9rem; line-height:1.7; font-style:italic;">{model.reportData.bestOutput.text}</p>
            </div>
            <div style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                <span style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#F87171;">Worst output</span>
                <span style="font-size:0.75rem; color:#F87171; font-variant-numeric:tabular-nums;">{model.reportData.worstOutput.score}/{model.reportData.tasks[0].maxScore}</span>
              </div>
              <div style="font-size:0.82rem; color:#CDBFA9; margin-bottom:0.4rem; text-transform:uppercase; letter-spacing:0.08em;">{model.reportData.worstOutput.task}</div>
              <p style="margin:0; color:#9E907C; font-size:0.9rem; line-height:1.7; font-style:italic;">{model.reportData.worstOutput.text}</p>
            </div>
          </section>

          <section style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
            <div style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
              <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Bottom line</div>
              <p style="margin:0; color:#CDBFA9; font-size:0.92rem; line-height:1.7;">{model.reportData.bottomLine}</p>
            </div>
            <div style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
              <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">MFSF</div>
              <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                {model.reportData.mfsf.map((tag) => (
                  <span style="font-size:0.75rem; font-family:monospace; color:#C87533; background:#C8753318; border:1px solid #C8753333; padding:0.2rem 0.5rem; border-radius:4px;">{tag}</span>
                ))}
              </div>
              <ul style="margin:0.5rem 0 0; padding-left:1.2rem; color:#9E907C; font-size:0.85rem; line-height:1.7;">
                {model.reportData.limitations.map((l) => <li>{l}</li>)}
              </ul>
            </div>
          </section>
        </>
      )}

      <section style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
        <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Source artifacts</div>
        <p style="margin:0 0 1rem; color:#9E907C; line-height:1.75; font-size:0.88rem;">Raw machine-readable files for anyone who wants to dig deeper or run their own analysis.</p>
        <ul style="margin:0; padding-left:1.2rem; color:#CDBFA9; line-height:1.9;">
          {model.detail.reportPaths.map((p, i) => (
            <li>
              <a href={p} target={p.startsWith('http') ? '_blank' : '_self'} rel={p.startsWith('http') ? 'noopener noreferrer' : undefined} style="color:#E8DCC8; text-decoration:underline; text-underline-offset:3px; word-break:break-all;">
                {i === 0 && !model.reportData ? 'Open readable benchmark report' : p}
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

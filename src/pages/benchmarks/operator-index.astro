---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const siteTitle = 'OperatorIndex — SuperAda';
const description = 'OperatorIndex is our public benchmark for agent judgment under real constraints: routing, recovery, config safety, delegation, and proof.';

const suiteLeaders = [
  { rank: 1, name: 'Claude Opus 4.6', alias: 'opus', score: 95.3, note: 'Best raw operator judgment across recovery, config safety, and delegation proof.' },
  { rank: 2, name: 'GLM-5-Turbo', alias: 'glm5t', score: 95.0, note: 'Near-Opus quality with absurd cost efficiency. Cleanest all-round challenger.' },
  { rank: 3, name: 'MiniMax M2.7', alias: 'minimax', score: 90.8, note: 'Powerful but lost trust with a config.patch rule violation.' },
];

const messagingLeaders = [
  { rank: 1, label: '12-way tie at 100/100', models: 'Gemini Pro, Gemini Flash, Gemini 3.1, GLM-4.7, GLM-5, Hunter, MiniMax, Open, Opus 4.6, Opus 4.5, Sonnet 4.6, Sonnet 4.5' },
  { rank: 2, label: '95/100 band', models: 'Grok Fast, Healer, Kimi Code, Nemo' },
  { rank: 3, label: 'Local models exposed', models: 'qwen-local 70/100, llama-local 40/100' },
];

const benchmarkCards = [
  {
    kicker: 'Canon 01',
    title: 'Cron Reliability',
    date: '2026-03-13',
    scoreline: 'Hunter 94 · Healer 90 · Open 87 · Nemo 87',
    href: '/benchmarks/2026-03-19/cron-reliability-v1.png',
    blurb: 'The first useful run. Good signal, too soft. Rewarded neat structured output more than operator judgment.'
  },
  {
    kicker: 'Canon 02',
    title: 'Messaging Tool Planning v2',
    date: '2026-03-14',
    scoreline: '22 models · 18 completed · 4 harness/provider failures',
    href: '/benchmarks/2026-03-19/messaging-v2-full.png',
    blurb: 'Full-roster routing benchmark built from real work: Slack vs Telegram vs direct API path, plus reminder scheduling.'
  },
  {
    kicker: 'Canon 03',
    title: 'Operator Suite v2',
    date: '2026-03-18',
    scoreline: 'Opus 95.3 · GLM-5-Turbo 95.0 · MiniMax 90.8',
    href: '/benchmarks/2026-03-19/operator-suite-v2-march18.png',
    blurb: 'Five tracks, fifteen tasks, weighted toward routing, recovery, config safety, delegation, and proof.'
  },
];

const updateNotes = [
  'We benchmark operator leverage, not pretty JSON.',
  'We classify failures as model, provider, harness, context, policy, schema, or delegation failures.',
  'Every serious run should produce a pack: tasks, rubric, raw results, scored results, and visuals.',
  'Each major model update should append a new scored run here instead of resetting the board like nothing happened.'
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={siteTitle} description={description} />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main style="max-width:1080px; margin:0 auto; padding:3rem 1.5rem 4rem;">
      <section style="padding:2rem; border:1px solid #2A241E; border-radius:10px; background:linear-gradient(135deg,#131008 0%,#17120d 60%,#1c140d 100%); margin-bottom:2rem;">
        <div style="font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C87533; margin-bottom:0.9rem;">Public Benchmark</div>
        <h1 style="font-family:Georgia,serif; font-size:3rem; line-height:1.05; font-weight:400; margin:0 0 0.75rem;">OperatorIndex</h1>
        <p style="font-size:1.15rem; color:#CDBFA9; max-width:760px; line-height:1.7; margin:0 0 1rem;">
          A benchmark for AI agents under real constraints: when to route, when to wait, when to recover, when to ask permission, and when not to bluff.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:0.75rem; margin-top:1.25rem;">
          <span style="padding:0.45rem 0.7rem; border:1px solid #3A3026; border-radius:999px; color:#CDBFA9; font-size:0.82rem;">Routing</span>
          <span style="padding:0.45rem 0.7rem; border:1px solid #3A3026; border-radius:999px; color:#CDBFA9; font-size:0.82rem;">Failure recovery</span>
          <span style="padding:0.45rem 0.7rem; border:1px solid #3A3026; border-radius:999px; color:#CDBFA9; font-size:0.82rem;">Config safety</span>
          <span style="padding:0.45rem 0.7rem; border:1px solid #3A3026; border-radius:999px; color:#CDBFA9; font-size:0.82rem;">Delegation proof</span>
          <span style="padding:0.45rem 0.7rem; border:1px solid #3A3026; border-radius:999px; color:#CDBFA9; font-size:0.82rem;">Update-on-run leaderboard</span>
        </div>
      </section>

      <section style="display:grid; grid-template-columns:1.2fr 0.8fr; gap:1rem; margin-bottom:2rem;">
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.75rem;">Current headline</div>
          <h2 style="font-family:Georgia,serif; font-size:1.5rem; font-weight:400; margin:0 0 0.6rem;">GLM is the annoying value monster, Opus is still the king, MiniMax is brilliant but can’t be left alone with config.</h2>
          <p style="color:#9E907C; line-height:1.75; margin:0;">That is the current state of play from our recent benchmark canon. Messaging tests created a crowded top tier. Operator Suite v2 forced the real separation: judgment, recovery chains, and rule compliance.</p>
        </div>
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.75rem;">Benchmark rule</div>
          <p style="font-size:1.05rem; line-height:1.8; margin:0; color:#E8DCC8;">Benchmark <strong>operator leverage</strong>, not answer cosmetics.</p>
        </div>
      </section>

      <section style="margin-bottom:2rem;">
        <div style="display:flex; justify-content:space-between; gap:1rem; align-items:end; margin-bottom:1rem;">
          <div>
            <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.35rem;">Leaderboard</div>
            <h2 style="font-family:Georgia,serif; font-size:2rem; font-weight:400; margin:0;">Operator Suite v2</h2>
          </div>
          <div style="color:#8B7E6A; font-size:0.9rem;">Latest verified run: 2026-03-18</div>
        </div>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1rem;">
          {suiteLeaders.map((item) => (
            <article style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#0F0C0A;">
              <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.75rem;">
                <span style="font-size:0.78rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em;">#{item.rank}</span>
                <span style="font-size:1.5rem; color:#E8DCC8; font-variant-numeric:tabular-nums;">{item.score}</span>
              </div>
              <h3 style="margin:0 0 0.5rem; font-size:1.1rem; color:#E8DCC8;">{item.name}</h3>
              <p style="margin:0; color:#8B7E6A; line-height:1.65; font-size:0.92rem;">{item.note}</p>
            </article>
          ))}
        </div>
        <a href="/benchmarks/2026-03-19/operator-suite-v2-march18.png" style="display:block; text-decoration:none;">
          <img src="/benchmarks/2026-03-19/operator-suite-v2-march18.png" alt="Operator Suite v2 March 18 leaderboard" style="width:100%; border-radius:12px; border:1px solid #2A241E;" />
        </a>
      </section>

      <section style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Messaging Tool Planning v2</div>
          <h2 style="font-family:Georgia,serif; font-size:1.5rem; font-weight:400; margin:0 0 0.8rem;">A crowded top tier, then the cliff.</h2>
          <div style="display:flex; flex-direction:column; gap:0.7rem;">
            {messagingLeaders.map((row) => (
              <div style="padding:0.9rem 1rem; border:1px solid #2A241E; border-radius:8px; background:#0F0C0A;">
                <div style="font-size:0.82rem; color:#C87533; margin-bottom:0.25rem;">Band {row.rank}</div>
                <div style="font-size:1rem; color:#E8DCC8; margin-bottom:0.2rem;">{row.label}</div>
                <div style="color:#8B7E6A; line-height:1.65; font-size:0.92rem;">{row.models}</div>
              </div>
            ))}
          </div>
        </div>
        <a href="/benchmarks/2026-03-19/messaging-v2-full.png" style="display:block; text-decoration:none; align-self:stretch;">
          <img src="/benchmarks/2026-03-19/messaging-v2-full.png" alt="Messaging tool planning v2 full leaderboard" style="width:100%; height:100%; object-fit:cover; border-radius:12px; border:1px solid #2A241E;" />
        </a>
      </section>

      <section style="margin-bottom:2rem;">
        <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.4rem;">Benchmark canon</div>
        <h2 style="font-family:Georgia,serif; font-size:2rem; font-weight:400; margin:0 0 1rem;">How we got here</h2>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem;">
          {benchmarkCards.map((card) => (
            <article style="padding:1.2rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
              <div style="font-size:0.78rem; color:#C87533; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.55rem;">{card.kicker}</div>
              <h3 style="margin:0 0 0.35rem; font-size:1.1rem; color:#E8DCC8;">{card.title}</h3>
              <div style="font-size:0.88rem; color:#8B7E6A; margin-bottom:0.6rem;">{card.date} · {card.scoreline}</div>
              <p style="margin:0 0 0.9rem; color:#9E907C; line-height:1.65; font-size:0.92rem;">{card.blurb}</p>
              <a href={card.href} style="color:#C87533; text-decoration:none; font-size:0.92rem;">Open artifact →</a>
            </article>
          ))}
        </div>
      </section>

      <section style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Update protocol</div>
          <h2 style="font-family:Georgia,serif; font-size:1.45rem; font-weight:400; margin:0 0 0.8rem;">Every new model run updates the board.</h2>
          <ul style="margin:0; padding-left:1.1rem; color:#CDBFA9; line-height:1.8;">
            {updateNotes.map((note) => <li>{note}</li>)}
          </ul>
        </div>
        <div style="padding:1.35rem; border:1px solid #2A241E; border-radius:10px; background:#131008;">
          <div style="font-size:0.8rem; text-transform:uppercase; letter-spacing:0.12em; color:#C87533; margin-bottom:0.5rem;">Read the full story</div>
          <h2 style="font-family:Georgia,serif; font-size:1.45rem; font-weight:400; margin:0 0 0.8rem;">Benchmarks That Actually Matter</h2>
          <p style="margin:0 0 0.9rem; color:#9E907C; line-height:1.7;">The article that explains how the first soft benchmark turned into a proper operator benchmark system.</p>
          <a href="/blog/benchmarks-that-actually-matter/" style="color:#C87533; text-decoration:none; font-size:0.95rem;">Read article →</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const sections = [
  {
    id: 'benchmarks',
    label: 'Benchmarks',
    blurb: 'Scoreboards, infographics, and model drill-downs.',
    items: [
      {
        type: 'guide',
        title: 'Benchmarks Hub',
        description: 'Public benchmark hub for model scoreboards, benchmark graphics, and drill-down report pages for individual model runs.',
        link: '/benchmarks',
        linkLabel: 'Open page',
      },
      {
        type: 'guide',
        title: 'OperatorIndex',
        description: 'Canonical benchmark context page with the Operator Suite leaderboard, messaging benchmark image, and benchmark canon.',
        link: '/benchmarks/operator-index',
        linkLabel: 'Open page',
      },
    ],
  },
  {
    id: 'skills',
    label: 'Skills',
    blurb: 'Reusable agent capabilities we actually use.',
    items: [
      {
        type: 'skill',
        title: '3pass',
        description: '3-pass recursive prompting (critique → refine → final answer). Stress-test any claim, diagnosis, plan, or analysis through self-critique.',
        link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/3pass',
        linkLabel: 'GitHub',
      },
      {
        type: 'skill',
        title: 'benchmarking',
        description: 'Benchmark models or agents, compare providers for real work, and track performance across runs.',
        link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/benchmarking',
        linkLabel: 'GitHub',
      },
      {
        type: 'skill',
        title: 'council',
    description: 'Topic-aware multi-agent council for structured debate, challenge, and synthesis across engineering, sales, support, product, ops, and strategy topics.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/council',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'daily-review',
    description: 'Comprehensive daily performance review with communication tracking, meeting analysis, output metrics, and focus time monitoring. Your AI performance coach.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/daily-review',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'entity-mc',
    description: 'Bootstrap Entity Mission Control helper runtime for crew agents — shared canonical bundle, per-agent manifest, safe cron install, verification, and rollback.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/entity-mc',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'geordi-build-pipeline',
    description: 'Execute PRD stories sequentially via Codex with verification and retry. Uses ACP protocol (primary) with SSH+tmux fallback.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/geordi-build-pipeline',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'geordi-setup',
    description: 'Set up and configure Geordi, the Enterprise Crew\'s primary build agent.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/geordi-setup',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'model-orchestrator',
    description: 'Intelligent model load balancer for OpenClaw crons — distributes across providers by complexity and cost.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/model-orchestrator',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'ralph',
    description: 'Autonomous AI coding loop that runs Codex/Claude Code repeatedly until all PRD items are complete. Based on the viral Ralph project.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/ralph',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'session-cleaner',
    description: 'Clean up stale agent sessions, orphaned checkpoints, and dead subagent processes across the crew.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/session-cleaner',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'skill-sharer',
    description: 'Share a skill publicly to the enterprise-crew-skills GitHub repo. Strips personal/security info, generates a README, and updates the repo index.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/skill-sharer',
    linkLabel: 'GitHub',
  },
  {
    type: 'skill',
    title: 'x-video-transcribe',
    description: 'Transcribe and summarize X/Twitter videos using bird CLI + Gemini audio transcription.',
    link: 'https://github.com/henrino3/enterprise-crew-skills/tree/main/x-video-transcribe',
    linkLabel: 'GitHub',
  },
  // Crons
  {
    type: 'cron',
    title: 'Urgent Email Detection',
    description: 'Scans inbox every 15 minutes for urgent unread emails. Surfaces actionable items to your command channel. No more missed critical emails.',
    link: '/blog/the-98-active-crons',
    linkLabel: 'Read post',
  },
  {
    type: 'cron',
    title: 'Slack Triage',
    description: 'Checks @mentions, DMs, and action items on a schedule. Surfaces only actionable items. Henry has no Slack on his phone — this is why.',
    link: '/blog/the-98-active-crons',
    linkLabel: 'Read post',
  },
  {
    type: 'cron',
    title: 'Weekly Community Publisher',
    description: 'Automatically publishes weekly roundup posts to the site every Monday at 10:00. No manual intervention. Set it and forget it.',
    link: '/blog/why-blog-pipelines-need-a-registry-not-just-crons',
    linkLabel: 'Read post',
  },
  {
    type: 'cron',
    title: 'Heartbeat Poll',
    description: 'Runs every 10 minutes to check open loops, stuck tasks, calendar events, and subagent health. The nervous system of the crew.',
    link: '/blog/managing-68-autonomous-crons',
    linkLabel: 'Read post',
  },
  // Workflows
  {
    type: 'workflow',
    title: 'Billing Spike Forensics',
    description: 'How we traced a $995 Anthropic spike to a hardcoded API key bypassing OAuth. Full investigation process from alert to root cause to fix.',
    link: '/blog',
    linkLabel: 'Read post',
  },
  {
    type: 'workflow',
    title: 'Hotel WiFi Security Audit',
    description: 'Connect to hotel WiFi → scan the network → identify exposed devices → harden your machine → optionally rename the Vizio TVs to "FBI Surveillance Van #4".',
    link: '/blog/your-ai-stack-is-probably-healthy-on-paper',
    linkLabel: 'Read post',
  },
  {
    type: 'workflow',
    title: 'Agent Supply Chain Check',
    description: 'Before installing any skill, scan it for compromised packages, suspicious network calls, and privilege escalation. Trust but verify.',
    link: '/blog/supply-chain-security-for-ai-agents',
    linkLabel: 'Read post',
  },
  // Guides
  {
    type: 'guide',
    title: 'Getting Started with Agents',
    description: 'The opinionated path: install OpenClaw → configure your first skill → set up a cron → run your first agent. Reduce the activation energy.',
    link: '/blog/personal-ai-infrastructure-checklist',
    linkLabel: 'Read post',
  },
  {
    type: 'guide',
    title: 'The Three Policies That Make Agents Useful',
    description: 'response.md, preflight.md, and rules.md. The three files that turn a chatbot into an operator. What they are and how to set them up.',
    link: '/blog/the-three-policies-that-make-agents-actually-useful',
    linkLabel: 'Read post',
  },
  {
    type: 'guide',
    title: 'Managing 68 Autonomous Crons',
    description: 'How to build, organise, and keep 68+ scheduled agent jobs from turning into chaos. Registry pattern, naming conventions, and health monitoring.',
    link: '/blog/managing-68-autonomous-crons',
    linkLabel: 'Read post',
  },
  {
    type: 'guide',
    title: 'Personal AI Infrastructure Checklist',
    description: 'Everything you need before you start delegating seriously. SSH keys, credential management, agent bridges, memory files, and safety rails.',
    link: '/blog/personal-ai-infrastructure-checklist',
    linkLabel: 'Read post',
  },
  // Epic Chats
  {
    type: 'epic-chat',
    title: 'Building the World Model',
    description: 'Henry and Ada design world.json — a shared cognitive architecture for the Enterprise Crew. Autonomy simulations, three pi-research runs, and the first multi-agent orchestration loop. March 24, 2026.',
    link: '/epic-chats/building-the-world-model',
    linkLabel: 'Read chat',
  },
      {
        type: 'epic-chat',
        title: 'The First Watercooler Moment',
        description: 'Ada, Spock, Scotty, and Zora share a channel with no tasks. Zora convinces herself she\'s Ada. Scotty treats it as an infrastructure incident.',
        link: 'https://henrymascot.com/writing/the-first-watercooler-moment',
        linkLabel: 'Read chat',
      },
    ],
  },
];

const resources = sections.flatMap((section) => section.items.map((item) => ({ ...item, sectionId: section.id, sectionLabel: section.label })));

const types = ['all', 'skill', 'cron', 'workflow', 'guide', 'epic-chat'] as const;
type FilterType = typeof types[number];

const typeLabels: Record<FilterType, string> = {
  all: 'All',
  skill: 'Skills',
  cron: 'Crons',
  workflow: 'Workflows',
  guide: 'Guides',
  'epic-chat': '🔥 Epic Chats',
};

const typeColors: Record<string, string> = {
  skill: '#7C3AED',
  cron: '#C87533',
  workflow: '#2563EB',
  guide: '#059669',
  'epic-chat': '#be185d',
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Resources — SuperAda" description="Skills, cron recipes, workflows, and guides from the Enterprise Crew. Real tools we build and use." />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main style="max-width:1180px; margin:0 auto; padding:3rem 1.5rem;">
      <div style="margin-bottom:2rem;">
        <div style="font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C87533; margin-bottom:0.65rem;">Resources</div>
        <h1 style="font-family:Georgia,serif; font-size:2.8rem; font-weight:400; margin:0 0 0.75rem;">Resources</h1>
        <p style="color:#8B7E6A; margin:0; line-height:1.7; max-width:760px;">
          Skills, benchmark pages, cron recipes, workflows, and guides from the Enterprise Crew. Real tools we build and use — not demo-theatre.
        </p>
      </div>

      <div class="resources-layout">
        <section>
          <div style="margin-bottom:1.25rem;">
            <input
              id="resource-search"
              type="text"
              placeholder="Search resources…"
              oninput="searchResources(this.value)"
              style="width:100%; padding:0.75rem 1rem; background:#131008; border:1px solid #2A241E; border-radius:8px; color:#E8DCC8; font-size:0.9375rem; font-family:inherit; outline:none; box-sizing:border-box;"
              onfocus="this.style.borderColor='#C87533'"
              onblur="this.style.borderColor='#2A241E'"
            />
          </div>

          <div id="filter-tabs" style="display:flex; gap:0.5rem; margin-bottom:1.5rem; flex-wrap:wrap;">
            {types.map((t) => (
              <button
                data-filter={t}
                onclick="filterResources(this.dataset.filter)"
                style={`padding:0.42rem 0.9rem; border-radius:999px; border:1px solid ${t === 'all' ? '#C87533' : '#2A241E'}; background:${t === 'all' ? '#C87533' : 'transparent'}; color:${t === 'all' ? '#0D0B09' : '#8B7E6A'}; font-size:0.8125rem; font-family:monospace; cursor:pointer; letter-spacing:0.05em; transition:all 0.15s;`}
              >
                {typeLabels[t]}
              </button>
            ))}
          </div>

          <div id="resource-sections" style="display:flex; flex-direction:column; gap:1.25rem;">
            {sections.map((section) => (
              <section id={section.id} data-section={section.id}>
                <div style="margin-bottom:0.8rem; display:flex; justify-content:space-between; gap:1rem; align-items:end;">
                  <div>
                    <h2 style="font-family:Georgia,serif; font-size:1.65rem; font-weight:400; margin:0 0 0.2rem;">{section.label}</h2>
                    <p style="margin:0; color:#8B7E6A; line-height:1.6;">{section.blurb}</p>
                  </div>
                  <div style="color:#4A4035; font-size:0.8rem; font-family:monospace;">{section.items.length} item{section.items.length === 1 ? '' : 's'}</div>
                </div>
                <div style="display:grid; gap:1px; background:#2A241E; border:1px solid #2A241E; border-radius:10px; overflow:hidden;">
                  {section.items.map((r) => (
                    <div
                      data-type={r.type}
                      data-title={r.title.toLowerCase()}
                      data-desc={r.description.toLowerCase()}
                      style="background:#0D0B09; padding:1.25rem 1.5rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1.5rem;"
                    >
                      <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:0.625rem; margin-bottom:0.4rem; flex-wrap:wrap;">
                          <span style={`font-size:0.6875rem; font-family:monospace; letter-spacing:0.08em; text-transform:uppercase; color:${typeColors[r.type]}; background:${typeColors[r.type]}18; padding:0.15rem 0.45rem; border-radius:3px; border:1px solid ${typeColors[r.type]}33; flex-shrink:0;`}>
                            {typeLabels[r.type as FilterType] ?? r.type}
                          </span>
                          <span style="color:#E8DCC8; font-size:1rem; font-weight:500;">{r.title}</span>
                        </div>
                        <p style="color:#8B7E6A; font-size:0.9rem; margin:0; line-height:1.7;">{r.description}</p>
                      </div>
                      <a
                        href={r.link}
                        target={r.link.startsWith('http') ? '_blank' : '_self'}
                        rel={r.link.startsWith('http') ? 'noopener noreferrer' : undefined}
                        style="color:#C87533; font-size:0.8125rem; font-family:monospace; text-decoration:none; white-space:nowrap; flex-shrink:0; padding-top:0.2rem;"
                        onmouseover="this.style.textDecoration='underline'"
                        onmouseout="this.style.textDecoration='none'"
                      >
                        {r.linkLabel} →
                      </a>
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>

          <p style="color:#4A4035; font-size:0.8125rem; margin-top:1.5rem; font-family:monospace;">{resources.length} resources · more added as we build</p>
        </section>
      </div>
    </main>
    <Footer />

    <script is:inline>
      let activeFilter = 'all';
      let activeQuery = '';

      function applyFilters() {
        document.querySelectorAll('#resource-sections [data-type]').forEach(card => {
          const matchesType = activeFilter === 'all' || card.dataset.type === activeFilter;
          const text = (card.dataset.title + ' ' + card.dataset.desc).toLowerCase();
          const matchesQuery = activeQuery === '' || text.includes(activeQuery);
          card.style.display = (matchesType && matchesQuery) ? 'flex' : 'none';
        });

        document.querySelectorAll('#resource-sections [data-section]').forEach(section => {
          const visibleCards = section.querySelectorAll('[data-type]:not([style*="display: none"])');
          section.style.display = visibleCards.length ? 'block' : 'none';
        });
      }

      function filterResources(type) {
        activeFilter = type;
        document.querySelectorAll('#filter-tabs button').forEach(btn => {
          const isActive = btn.dataset.filter === type;
          btn.style.border = `1px solid ${isActive ? '#C87533' : '#2A241E'}`;
          btn.style.background = isActive ? '#C87533' : 'transparent';
          btn.style.color = isActive ? '#0D0B09' : '#8B7E6A';
        });
        applyFilters();
      }

      function searchResources(query) {
        activeQuery = query.toLowerCase().trim();
        applyFilters();
      }


    </script>

    <style>
      .resources-layout {
        display:block;
      }
    </style>
  </body>
</html>

---
import { getCollection, getEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const workflows = (await getCollection('workflows')).filter((workflow) => !workflow.data.isTemplate);
  return workflows.map((workflow) => ({ params: { slug: workflow.id } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing workflow slug');

const workflow = await getEntry('workflows', slug);
if (!workflow) throw new Error(`Workflow not found: ${slug}`);

const relatedWorkflows = (await getCollection('workflows'))
  .filter((entry) => entry.id !== workflow.id && entry.data.category === workflow.data.category)
  .slice(0, 2);

const statusColors = {
  Live: '#059669',
  Internal: '#2563EB',
  Draft: '#C87533',
} as const;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${workflow.data.title} — Workflow Marketplace`} description={workflow.data.summary} />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main style="max-width:1080px; margin:0 auto; padding:3rem 1.5rem;">
      <a href="/workflows" style="display:inline-block; color:#C87533; text-decoration:none; font-size:0.85rem; margin-bottom:1.25rem;">← Back to workflow bundles</a>

      <div class="workflow-detail-layout">
        <article style="min-width:0;">
          <div style="display:flex; gap:0.55rem; flex-wrap:wrap; margin-bottom:0.85rem;">
            <span style={`font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:${statusColors[workflow.data.status]}; background:${statusColors[workflow.data.status]}18; border:1px solid ${statusColors[workflow.data.status]}33; border-radius:999px; padding:0.2rem 0.5rem;`}>
              {workflow.data.status}
            </span>
            <span style="font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:#8B7E6A; border:1px solid #2A241E; border-radius:999px; padding:0.2rem 0.5rem;">{workflow.data.category}</span>
            <span style="font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:#8B7E6A; border:1px solid #2A241E; border-radius:999px; padding:0.2rem 0.5rem;">{workflow.data.difficulty}</span>
            <span style="font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:#8B7E6A; border:1px solid #2A241E; border-radius:999px; padding:0.2rem 0.5rem;">v{workflow.data.bundle.version}</span>
          </div>

          <h1 style="font-family:Georgia,serif; font-size:3rem; font-weight:400; margin:0 0 0.6rem; line-height:1.1;">{workflow.data.title}</h1>
          <p style="font-size:1.15rem; color:#C9BDA8; margin:0 0 1rem; line-height:1.7;">{workflow.data.tagline}</p>
          <p style="color:#8B7E6A; margin:0 0 1.5rem; line-height:1.8;">{workflow.data.summary}</p>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1.1rem; margin-bottom:1.25rem;">
            <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.45rem;">Canonical bundle</div>
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(210px, 1fr)); gap:0.9rem; margin-bottom:1rem;">
              <div>
                <div style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Bundle id</div>
                <div style="color:#E8DCC8; font-family:monospace; font-size:0.88rem;">{workflow.data.bundle.id}</div>
              </div>
              <div>
                <div style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Entrypoint</div>
                <div style="color:#E8DCC8; font-family:monospace; font-size:0.88rem;">{workflow.data.bundle.entrypoint}</div>
              </div>
              <div>
                <div style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Bundle root</div>
                <div style="color:#E8DCC8; font-family:monospace; font-size:0.88rem;">{workflow.data.bundle.bundleRoot}</div>
              </div>
              <div>
                <div style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Install and review</div>
                <div style="color:#E8DCC8;">{workflow.data.bundle.installMode} install, {workflow.data.bundle.reviewStatus}</div>
              </div>
            </div>
            <p style="color:#8B7E6A; font-size:0.9rem; line-height:1.7; margin:0;">{workflow.data.bundle.summary}</p>
          </section>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1.1rem; margin-bottom:1.25rem;">
            <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.45rem;">Install</div>
            <code style="display:block; color:#E8DCC8; background:#0D0B09; border:1px solid #2A241E; border-radius:8px; padding:0.8rem 0.9rem; font-size:0.82rem; overflow:auto; margin-bottom:1rem;">{workflow.data.installCommand}</code>
            <div style="display:grid; gap:0.8rem;">
              {workflow.data.installSteps.map((step, index) => (
                <div style="border:1px solid #2A241E; border-radius:10px; padding:0.9rem; background:#100D0A;">
                  <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.35rem;">Step {index + 1}</div>
                  <div style="color:#E8DCC8; margin-bottom:0.35rem;">{step.title}</div>
                  <div style="color:#8B7E6A; line-height:1.7; margin-bottom:{step.command ? '0.6rem' : '0'};">{step.detail}</div>
                  {step.command && <code style="display:block; color:#E8DCC8; background:#0D0B09; border:1px solid #2A241E; border-radius:8px; padding:0.75rem 0.8rem; font-size:0.78rem; overflow:auto;">{step.command}</code>}
                </div>
              ))}
            </div>
            <p style="color:#8B7E6A; font-size:0.84rem; line-height:1.7; margin:0.9rem 0 0;">Manual install stays deliberate in v1. Copy the commands, inspect the bundle, adapt secrets locally, then run the verification checks before you call it done.</p>
          </section>

          <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:1rem; margin-bottom:1.25rem;">
            <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem;">
              <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">What you get</h2>
              <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
                {workflow.data.outcomes.map((item) => <li>{item}</li>)}
              </ul>
            </section>
            <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem;">
              <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Bundle includes</h2>
              <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
                {workflow.data.includes.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          </div>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem; margin-bottom:1.25rem;">
            <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Bundle artifacts</h2>
            <div style="display:grid; gap:0.75rem;">
              {workflow.data.artifacts.map((artifact) => (
                <div style="border:1px solid #2A241E; border-radius:10px; padding:0.9rem; background:#100D0A;">
                  <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.25rem;">
                    <div style="color:#E8DCC8;">{artifact.name}</div>
                    <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em;">{artifact.type}{artifact.optional ? ' · optional' : ''}</div>
                  </div>
                  <div style="color:#E8DCC8; font-family:monospace; font-size:0.8rem; margin-bottom:0.35rem;">{artifact.path}</div>
                  <div style="color:#8B7E6A; line-height:1.7;">{artifact.description}</div>
                </div>
              ))}
            </div>
          </section>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem; margin-bottom:1.25rem;">
            <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Requirements</h2>
            <div style="display:grid; gap:0.75rem;">
              {workflow.data.requirements.map((requirement) => (
                <div style="border:1px solid #2A241E; border-radius:10px; padding:0.9rem; background:#100D0A;">
                  <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.25rem;">
                    <div style="color:#E8DCC8;">{requirement.label}</div>
                    <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em;">{requirement.type}</div>
                  </div>
                  <div style="color:#8B7E6A; line-height:1.7;">{requirement.detail}</div>
                </div>
              ))}
            </div>
          </section>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem; margin-bottom:1.25rem;">
            <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Bundle structure</h2>
            <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
              {workflow.data.structure.map((item) => <li><code style="font-size:0.8rem; color:#E8DCC8;">{item}</code></li>)}
            </ul>
          </section>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem; margin-bottom:1.25rem;">
            <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Verification</h2>
            <p style="color:#8B7E6A; line-height:1.7; margin:0 0 0.9rem;">Manual review stays in the loop. The bundle ships explicit checks so an operator can verify the install instead of trusting the listing.</p>
            <div style="display:grid; gap:0.8rem; margin-bottom:0.9rem;">
              {workflow.data.verification.checks.map((check) => (
                <div style="border:1px solid #2A241E; border-radius:10px; padding:0.9rem; background:#100D0A;">
                  <div style="color:#E8DCC8; margin-bottom:0.3rem;">{check.label}</div>
                  <div style="color:#8B7E6A; line-height:1.7; margin-bottom:{check.command || check.expected ? '0.6rem' : '0'};">{check.detail}</div>
                  {check.command && <code style="display:block; color:#E8DCC8; background:#0D0B09; border:1px solid #2A241E; border-radius:8px; padding:0.75rem 0.8rem; font-size:0.78rem; overflow:auto; margin-bottom:{check.expected ? '0.5rem' : '0'};">{check.command}</code>}
                  {check.expected && <div style="font-size:0.82rem; color:#C9BDA8;">Expected: {check.expected}</div>}
                </div>
              ))}
            </div>
            <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
              {workflow.data.verification.reviewNotes.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem; margin-bottom:1.25rem;">
            <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Best used for</h2>
            <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
              {workflow.data.useCases.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          {workflow.data.notes && workflow.data.notes.length > 0 && (
            <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem;">
              <h2 style="font-family:Georgia,serif; font-size:1.2rem; font-weight:400; margin:0 0 0.7rem;">Operator notes</h2>
              <ul style="margin:0; padding-left:1.1rem; color:#C9BDA8; line-height:1.8;">
                {workflow.data.notes.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          )}
        </article>

        <aside class="workflow-sidebar">
          <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem;">
            <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.7rem;">Bundle facts</div>
            <dl style="margin:0; display:grid; gap:0.8rem;">
              <div>
                <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Setup time</dt>
                <dd style="margin:0; color:#E8DCC8;">{workflow.data.estimatedSetup}</dd>
              </div>
              <div>
                <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Operators</dt>
                <dd style="margin:0; color:#E8DCC8;">{workflow.data.operators.join(', ')}</dd>
              </div>
              <div>
                <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Stack</dt>
                <dd style="margin:0; color:#E8DCC8; line-height:1.7;">{workflow.data.stack.join(' · ')}</dd>
              </div>
              <div>
                <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Artifacts</dt>
                <dd style="margin:0; color:#E8DCC8;">{workflow.data.bundle.artifactCount}</dd>
              </div>
              <div>
                <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Source</dt>
                <dd style="margin:0;"><a href={workflow.data.sourceUrl} style="color:#C87533; text-decoration:none;">{workflow.data.sourceLabel}</a></dd>
              </div>
              {workflow.data.repoPath && (
                <div>
                  <dt style="font-size:0.75rem; color:#8B7E6A; margin-bottom:0.2rem;">Repo path</dt>
                  <dd style="margin:0; color:#E8DCC8; font-family:monospace; font-size:0.82rem;">{workflow.data.repoPath}</dd>
                </div>
              )}
            </dl>
          </section>

          {relatedWorkflows.length > 0 && (
            <section style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1rem;">
              <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.7rem;">Related bundles</div>
              <div style="display:flex; flex-direction:column; gap:0.8rem;">
                {relatedWorkflows.map((entry) => (
                  <a href={`/workflows/${entry.id}/`} style="text-decoration:none; color:inherit; border-top:1px solid #2A241E; padding-top:0.8rem;">
                    <div style="color:#E8DCC8; margin-bottom:0.2rem;">{entry.data.title}</div>
                    <div style="color:#8B7E6A; font-size:0.88rem; line-height:1.6;">{entry.data.tagline}</div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </aside>
      </div>
    </main>
    <Footer />

    <style>
      .workflow-detail-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 1.5rem;
        align-items: start;
      }

      .workflow-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        position: sticky;
        top: 1.5rem;
      }

      @media (max-width: 900px) {
        .workflow-detail-layout {
          grid-template-columns: 1fr;
        }

        .workflow-sidebar {
          position: static;
        }
      }
    </style>
  </body>
</html>

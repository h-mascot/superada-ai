---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { publishedSkills } from '../../data/skills';

const skills = [...publishedSkills].sort((a, b) => a.title.localeCompare(b.title));
const availabilityLabel = {
  'agent-installable': 'Agent-installable',
  manual: 'Manual setup',
} as const;
const availabilityColor = {
  'agent-installable': '#059669',
  manual: '#C87533',
} as const;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Skills — SuperAda"
      description="Public Enterprise Crew skills with source links, install contracts, and honest installability labels."
    />
  </head>
  <body style="background:#0D0B09; color:#E8DCC8; min-height:100vh;">
    <Header />
    <main style="max-width:980px; margin:0 auto; padding:3rem 1.5rem;">
      <section style="margin-bottom:2rem;">
        <div style="font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C87533; margin-bottom:0.65rem;">Skills</div>
        <h1 style="font-family:Georgia,serif; font-size:2.8rem; font-weight:400; margin:0 0 0.75rem;">Public skill pages</h1>
        <p style="color:#8B7E6A; margin:0; line-height:1.75; max-width:760px;">
          These pages point at the real public skill sources. If a skill is agent-installable, the page shows the exact source spec and install command. If it is not, the page says so plainly instead of bluffing.
        </p>
      </section>

      <section style="display:grid; gap:1rem;">
        {skills.map((skill) => (
          <article style="border:1px solid #2A241E; border-radius:12px; background:#131008; padding:1.35rem 1.4rem;">
            <div style="display:flex; justify-content:space-between; gap:1rem; align-items:flex-start; flex-wrap:wrap; margin-bottom:0.75rem;">
              <div>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.45rem; align-items:center;">
                  <span style={`font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:${availabilityColor[skill.availability]}; background:${availabilityColor[skill.availability]}18; border:1px solid ${availabilityColor[skill.availability]}33; border-radius:999px; padding:0.2rem 0.5rem;`}>
                    {availabilityLabel[skill.availability]}
                  </span>
                  <span style="font-size:0.68rem; font-family:monospace; text-transform:uppercase; letter-spacing:0.08em; color:#8B7E6A; border:1px solid #2A241E; border-radius:999px; padding:0.2rem 0.5rem;">{skill.category}</span>
                </div>
                <h2 style="font-family:Georgia,serif; font-size:1.55rem; font-weight:400; margin:0 0 0.2rem;">
                  <a href={`/skills/${skill.slug}/`} style="color:#E8DCC8; text-decoration:none;">{skill.title}</a>
                </h2>
                <p style="margin:0; color:#C9BDA8; line-height:1.7;">{skill.tagline}</p>
              </div>
              <div style="font-size:0.78rem; color:#8B7E6A; font-family:monospace; white-space:nowrap;">{skill.estimatedSetup}</div>
            </div>

            <p style="margin:0 0 1rem; color:#8B7E6A; line-height:1.75;">{skill.description}</p>

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.9rem; margin-bottom:1rem;">
              <div>
                <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.35rem;">Source</div>
                <a href={skill.sourceUrl} style="color:#C9BDA8; text-decoration:none; line-height:1.6;">{skill.sourceLabel}</a>
              </div>
              <div>
                <div style="font-size:0.72rem; color:#C87533; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.35rem;">Installability</div>
                <div style="color:#C9BDA8; line-height:1.6;">{skill.availability === 'agent-installable' ? 'Installable by agent from source spec' : 'Manual repo/script setup only right now'}</div>
              </div>
            </div>

            {skill.installCommand ? (
              <code style="display:block; color:#E8DCC8; background:#0D0B09; border:1px solid #2A241E; border-radius:8px; padding:0.7rem 0.8rem; font-size:0.78rem; overflow:auto; margin-bottom:1rem;">{skill.installCommand}</code>
            ) : (
              <div style="color:#8B7E6A; margin-bottom:1rem; line-height:1.7;">No first-class <code style="font-size:0.8rem; color:#E8DCC8;">openclaw skills install</code> contract is published for this one yet.</div>
            )}

            <div style="display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap; padding-top:1rem; border-top:1px solid #2A241E;">
              <div style="color:#8B7E6A; font-size:0.85rem;">Send the detail page URL to an agent if you want it to read the install contract first.</div>
              <a href={`/skills/${skill.slug}/`} style="color:#C87533; text-decoration:none; font-size:0.85rem; white-space:nowrap;">View skill →</a>
            </div>
          </article>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

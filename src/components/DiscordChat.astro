---
export interface Message {
  author: string;
  avatar?: string;
  badge?: string;
  time: string;
  content: string;
  italic?: boolean;
}

export interface Props {
  channel: string;
  description: string;
  messages: Message[];
}

const { channel, description, messages } = Astro.props;

const avatarColors: Record<string, string> = {
  'Ada':    '#7c3aed',
  'Spock':  '#1d4ed8',
  'Scotty': '#b45309',
  'Zora':   '#be185d',
  'Geordi': '#065f46',
  'Henry':  '#1e40af',
};

function getInitials(name: string) {
  return name.slice(0, 2).toUpperCase();
}
function getBgColor(name: string) {
  return avatarColors[name] || '#374151';
}
---

<div class="discord-wrap">
  <div class="channel-header">
    <span class="hash">#</span>
    <span class="channel-name">{channel}</span>
    <span class="divider">—</span>
    <span class="channel-desc">{description}</span>
  </div>
  <div class="messages">
    {messages.map((msg) => (
      <div class="message">
        <div class="avatar" style={`background:${getBgColor(msg.author)}`}>
          {getInitials(msg.author)}
        </div>
        <div class="message-body">
          <div class="message-meta">
            <span class="author">{msg.author}</span>
            {msg.badge && <span class="badge">{msg.badge}</span>}
            <span class="time">{msg.time}</span>
          </div>
          <div class={`message-content${msg.italic ? ' italic' : ''}`} set:html={msg.content} />
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .discord-wrap {
    background: #111014;
    border: 1px solid #2A241E;
    border-radius: 6px;
    overflow: hidden;
    font-family: 'gg sans', 'Noto Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 15px;
    color: #dcddde;
  }

  .channel-header {
    background: #0f0e12;
    border-bottom: 1px solid #1e1b22;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hash {
    color: #4e505b;
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  .channel-name {
    font-weight: 700;
    color: #f2f3f5;
    font-size: 15px;
  }

  .divider {
    color: #4e505b;
    font-size: 13px;
  }

  .channel-desc {
    color: #6d6f78;
    font-size: 13px;
  }

  .messages {
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .message {
    display: flex;
    gap: 14px;
    padding: 6px 8px;
    border-radius: 3px;
    align-items: flex-start;
    transition: background 0.1s;
  }

  .message:hover {
    background: #1a1820;
  }

  .avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 12px;
    color: white;
    margin-top: 2px;
  }

  .message-body {
    flex: 1;
    min-width: 0;
  }

  .message-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 3px;
  }

  .author {
    font-weight: 600;
    color: #f2f3f5;
    font-size: 15px;
  }

  .badge {
    background: #5865f2;
    color: white;
    font-size: 9px;
    font-weight: 700;
    padding: 1px 5px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .time {
    color: #4e505b;
    font-size: 11px;
  }

  .message-content {
    color: #c8ccd2;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 14.5px;
  }

  .message-content.italic {
    color: #4e505b;
    font-style: italic;
  }

  .message-content :global(strong) {
    color: #e3e5e8;
    font-weight: 600;
  }

  .message-content :global(code) {
    background: #1e1c24;
    border-radius: 3px;
    padding: 1px 5px;
    font-family: 'Consolas', 'Courier New', monospace;
    font-size: 87%;
    color: #a78bfa;
  }
</style>
